{
  "ejercicios": [
    {
      "id": 5,
      "nombre": {
        "identificador": "press-de-banca",
        "visible": "Press de banca"
      },
      "descripcion": {
        "resumen": "Este es un ejercicio para el pecho."
      },
      "clasificacion": {
        "tipo": {
          "nombre": "compuesto"
        }
      },
      "musculos": {
        "principal": {
          "nombre": "pecho"
        },
        "secundarios": [
          {
            "nombre": "triceps"
          }
        ]
      },
      "material": {
        "equipo": [
          {
            "elemento": {
              "nombre": "banco",
              "tipo": "soporte"
            }
          },
          {
            "elemento": {
              "nombre": "barra",
              "tipo": "peso libre"
            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Tumbate en un banco plano con los pies apoyados en el suelo y la espalda apoyada en el banco."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Agarra la barra un poco mas abierta que la anchura de los hombros."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Eleva la barra por encima del cuerpo y colócala sobre la parte media del pecho; esta es la posicion inicial."
            }
          },
          {
            "paso": {
              "numero": 4,
              "texto": "Baja la barra hasta que toque ligeramente el pecho."
            }
          },
          {
            "paso": {
              "numero": 5,
              "texto": "Empuja la barra hacia arriba hasta extender completamente los brazos."
            }
          },
          {
            "paso": {
              "numero": 6,
              "texto": "Vuelve a la posicion inicial."
            }
          }
        ]
      }
    },
    {
      "id": 10,
      "nombre": {
        "identificador": "press-tate",
        "visible": "Press Tate"
      },
      "descripcion": {
        "resumen": "Este es un ejercicio avanzado para triceps que trabaja el musculo de forma diferente a otros ejercicios."
      },
      "clasificacion": {
        "tipo": {
          "nombre": "aislamiento"
        }
      },
      "musculos": {
        "principal": {
          "nombre": "triceps"
        },
        "secundarios": []
      },
      "material": {
        "equipo": [
          {
            "elemento": {
              "nombre": "mancuerna",
              "tipo": "peso libre"
            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Tumbate en un banco con la cabeza en un extremo y los pies firmemente apoyados en el suelo."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Sujeta una mancuerna en cada mano con las palmas orientadas hacia los pies."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Contrae el abdomen y mantén la espalda apoyada en el banco mientras llevas las pesas al centro del pecho."
            }
          },
          {
            "paso": {
              "numero": 4,
              "texto": "Sin mover los codos, eleva lentamente los brazos hacia arriba y hacia fuera contrayendo los triceps."
            }
          }
        ]
      }
    },
    {
      "id": 15,
      "nombre": {
        "identificador": "flexion-extension-estatica-del-cuello",
        "visible": "Flexion y extension estatica del cuello"
      },
      "descripcion": {
        "resumen": "Ejercicio para fortalecer o calentar la parte delantera y trasera del cuello."
      },
      "clasificacion": {
        "tipo": {
          "nombre": "isometrico"
        }
      },
      "musculos": {
        "principal": {
          "nombre": "extensores y flexores del cuello"
        },
        "secundarios": []
      },
      "material": {
        "equipo": [
          {
            "elemento": {
              "nombre": "cuerpo",
              "tipo": "peso corporal"
            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Colocate de pie o sentado con la cabeza en posicion neutral."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Pon ambas manos sobre la frente."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Empuja la cabeza contra las manos y contrae los musculos del cuello."
            }
          },
          {
            "paso": {
              "numero": 4,
              "texto": "Evita que la cabeza se desplace hacia delante y mantén la posicion al menos 30 segundos."
            }
          },
          {
            "paso": {
              "numero": 5,
              "texto": "Repite colocando las manos en la parte posterior de la cabeza."
            }
          }
        ]
      }
    },
    {
      "id": 20,
      "nombre": {
        "identificador": "flexion-lateral-estatica-del-cuello",
        "visible": "Flexion lateral estatica del cuello"
      },
      "descripcion": {
        "resumen": "Ejercicio para fortalecer o calentar los flexores laterales del cuello."
      },
      "clasificacion": {
        "tipo": {
          "nombre": "isometrico"
        }
      },
      "musculos": {
        "principal": {
          "nombre": "flexores laterales del cuello"
        },
        "secundarios": []
      },
      "material": {
        "equipo": [
          {
            "elemento": {
              "nombre": "cuerpo",
              "tipo": "peso corporal"
            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Colocate de pie o sentado con la cabeza en posicion neutral."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Pon la mano izquierda en el lado izquierdo de la cabeza, por encima de la oreja."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Empuja la cabeza contra la mano sin moverla."
            }
          },
          {
            "paso": {
              "numero": 4,
              "texto": "Repite con la mano derecha en el lado derecho de la cabeza."
            }
          }
        ],
        "consejos": [
          {
            "consejo": {
              "texto": "Mantén la barbilla en un angulo aproximado de 90 grados respecto al cuello."
            }
          }
        ]
      }
    },
    {
      "id": 25,
      "nombre": {
        "identificador": "press-de-hombros-en-maquina-sentado",
        "visible": "Press de hombros en maquina sentado"
      },
      "descripcion": {
        "resumen": "Este es un ejercicio para fortalecer los hombros."
      },
      "clasificacion": {
        "tipo": {
          "nombre": "aislamiento"
        }
      },
      "musculos": {
        "principal": {
          "nombre": "hombros"
        },
        "secundarios": [
          {
            "nombre": "triceps"
          }
        ]
      },
      "material": {
        "equipo": [
          {
            "elemento": {
              "nombre": "maquina",
              "tipo": "maquina guiada"
            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Sientate erguido con la espalda apoyada en el respaldo y el abdomen contraido."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Coloca las manos en las barras y empuja hacia arriba con un movimiento suave, extendiendo los brazos sin bloquearlos."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Haz una breve pausa arriba y baja las barras de forma controlada hasta la posicion inicial."
            }
          }
        ],
        "consejos": [
          {
            "consejo": {
              "texto": "Asegurate de ajustar el asiento y las barras para mantener una postura correcta."
            }
          }
        ]
      }
    },
    {
      "id": 30,
      "nombre": {
        "identificador": "press-militar-sentado",
        "visible": "Press militar sentado"
      },
      "descripcion": {
        "resumen": "Ejercicio para fortalecer hombros y triceps."
      },
      "clasificacion": {
        "tipo": {
          "nombre": "aislamiento"
        }
      },
      "musculos": {
        "principal": {
          "nombre": "hombros"
        },
        "secundarios": [
          {
            "nombre": "triceps"
          }
        ]
      },
      "material": {
        "equipo": [
          {
            "elemento": {
              "nombre": "barra",
              "tipo": "peso libre"
            }
          },
          {
            "elemento": {
              "nombre": "banco",
              "tipo": "soporte"
            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Sientate en el banco con la espalda recta, el abdomen contraido y los pies orientados hacia delante."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Agarra la barra con las palmas hacia fuera y las manos separadas al ancho de los hombros."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Con la barra delante de la cabeza, empuja hacia arriba extendiendo los brazos sin bloquearlos."
            }
          },
          {
            "paso": {
              "numero": 4,
              "texto": "Haz una pausa arriba y baja la barra de forma controlada hasta la posicion inicial."
            }
          }
        ],
        "consejos": [
          {
            "consejo": {
              "texto": "Procura que caderas, rodillas y tobillos formen angulos de 90 grados para mejorar la postura."
            }
          }
        ]
      }
    },
    {
      "id": 35,
      "nombre": {
        "identificador": "encogimientos-de-hombros",
        "visible": "Encogimientos de hombros"
      },
      "descripcion": {
        "resumen": "Ejercicio para fortalecer el trapecio."
      },
      "clasificacion": {
        "tipo": {
          "nombre": "aislamiento"
        }
      },
      "musculos": {
        "principal": {
          "nombre": "trapecio"
        },
