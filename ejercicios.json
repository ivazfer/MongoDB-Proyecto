          }
        ]
      },
      "material": {
        "equipo": [
          {
            "elemento": {
              "nombre": "mancuernas",
              "tipo": "peso libre"
            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Sientate en un banco plano con los pies hacia delante y el abdomen contraido."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Sujeta una mancuerna en cada mano con las palmas orientadas hacia el cuerpo."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Flexiona los codos a 90 grados y eleva los brazos hasta la altura de los hombros."
            }
          },
          {
            "paso": {
              "numero": 4,
              "texto": "Empuja las mancuernas hacia arriba mientras extiendes los codos y giras los antebrazos hasta que las palmas miren hacia fuera."
            }
          },
          {
            "paso": {
              "numero": 5,
              "texto": "Acerca las mancuernas sin bloquear completamente los codos."
            }
          },
          {
            "paso": {
              "numero": 6,
              "texto": "Baja las mancuernas de forma controlada hasta la posicion inicial."
            }
          }
        ],
        "consejos": [
          {
            "consejo": {
              "texto": "Empieza con poco peso para perfeccionar la tecnica."
            }
          },
          {
            "consejo": {
              "texto": "No hagas este ejercicio si tienes dolor de hombro."
            }
          }
        ]
      }
