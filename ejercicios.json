            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Colocate de pie con los pies separados al ancho de los hombros, el abdomen contraido y las rodillas ligeramente flexionadas."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Sujeta una mancuerna en cada mano con las palmas hacia abajo."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Comienza con las mancuernas a la altura de la cintura."
            }
          },
          {
            "paso": {
