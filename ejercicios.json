      },
      "material": {
        "equipo": [
          {
            "elemento": {
              "nombre": "mancuernas",
              "tipo": "peso libre"
            }
          }
        ]
      },
      "ejecucion": {
        "pasos": [
          {
            "paso": {
              "numero": 1,
              "texto": "Colocate de pie con los pies separados al ancho de los hombros y una ligera flexion de rodillas."
            }
          },
          {
            "paso": {
              "numero": 2,
              "texto": "Sujeta una mancuerna en cada mano con los brazos a los lados."
            }
          },
          {
            "paso": {
              "numero": 3,
              "texto": "Baja los hombros todo lo posible."
            }
          },
          {
            "paso": {
              "numero": 4,
              "texto": "Con los brazos rectos, eleva ambos hombros hacia las orejas."
            }
          },
          {
            "paso": {
              "numero": 5,
              "texto": "Mantén la posicion un instante y desciende de forma controlada."
            }
          }
        ],
        "consejos": [
          {
            "consejo": {
              "texto": "No realices este ejercicio si tienes dolor de cuello o de hombros."
            }
          }
        ]
      }
    },
    {
